p          = 1
hh1        = c(1:60)
boot       = TRUE
block_size <- 4
conf1      <- 0.32
conf2      <- 0.1
color         = "blue4"
#----------------------------------------------
# Estimation of a BVAR using the package bsvars
#----------------------------------------------
pLags      = 3
nSteps     = 60
Confidence = 1-conf1
Var_shock  = c('ShockBloom')
