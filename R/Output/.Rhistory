hh1        = c(1:60)
boot       = TRUE
block_size <- 4
conf1      <- 0.32
conf2      <- 0.1
color         = "blue4"
for(ss in MP_shocks){
#shock_anal = MP_shocks[1]
shock_anal  = ss
